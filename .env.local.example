# Lester Labs Configuration
# Copy this file to .env.local and fill in the values

# WalletConnect Project ID (REQUIRED)
# Get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# LitVM RPC
NEXT_PUBLIC_LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/infra-partner-http

# ─── Contract Addresses ───────────────────────────────────────────────────────

# Token Factory - creates new ERC20 tokens
NEXT_PUBLIC_TOKEN_FACTORY_ADDRESS=

# Vesting Factory - creates token vesting schedules
NEXT_PUBLIC_VESTING_FACTORY_ADDRESS=

# Liquidity Locker - locks LP tokens
NEXT_PUBLIC_LIQUIDITY_LOCKER_ADDRESS=

# Disperse - batch token/ETH distribution
NEXT_PUBLIC_DISPERSE_ADDRESS=

# ILO Factory - creates Initial Liquidity Offerings
NEXT_PUBLIC_ILO_FACTORY_ADDRESS=

# Lester Labs DEX (Uniswap V2 fork)
NEXT_PUBLIC_UNISWAP_V2_FACTORY_ADDRESS=0x017A126A44Aaae9273F7963D4E295F0Ee2793AD8
NEXT_PUBLIC_UNISWAP_V2_ROUTER_ADDRESS=0xD56a623890b083d876D47c3b1c5343b7f983FA62
NEXT_PUBLIC_WRAPPED_ZKLTC_ADDRESS=0xd141A5DDE1a3A373B7e9bb603362A58793AB9D97

# Ledger - on-chain message board
NEXT_PUBLIC_LEDGER_ADDRESS=
