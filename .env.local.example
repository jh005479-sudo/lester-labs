# Lester Labs Configuration
# Copy this file to .env.local and fill in the values

# WalletConnect Project ID (REQUIRED)
# Get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Contract Addresses ───────────────────────────────────────────────────────

# Token Factory - creates new ERC20 tokens
NEXT_PUBLIC_TOKEN_FACTORY_ADDRESS=

# Vesting Factory - creates token vesting schedules
NEXT_PUBLIC_VESTING_FACTORY_ADDRESS=

# Liquidity Locker - locks LP tokens
NEXT_PUBLIC_LIQUIDITY_LOCKER_ADDRESS=

# Disperse - batch token/ETH distribution
NEXT_PUBLIC_DISPERSE_ADDRESS=

# ILO Factory - creates Initial Liquidity Offerings
# Current LitVM testnet deployment:
NEXT_PUBLIC_ILO_FACTORY_ADDRESS=0xA533bBe87bdCD91e4367de517e99bf8BA75Fd0aB
